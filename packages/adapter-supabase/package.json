{
  "name": "@baas/adapter-supabase",
  "version": "0.0.0",
  "description": "Supabase adapter: PostgREST document store, Supabase Auth (credential management), and Supabase Storage, behind the @baas/core ports.",
  "keywords": [
    "baas",
    "backend-as-a-service",
    "ports-and-adapters",
    "typescript",
    "esm",
    "supabase",
    "postgrest",
    "postgres",
    "auth",
    "file-storage"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2bTwist/baasdk.git",
    "directory": "packages/adapter-supabase"
  },
  "homepage": "https://github.com/2bTwist/baasdk/tree/main/packages/adapter-supabase#readme",
  "bugs": "https://github.com/2bTwist/baasdk/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint:publish": "publint --strict && attw --pack . --profile esm-only"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2"
  },
  "dependencies": {
    "@baas/core": "workspace:^"
  },
  "devDependencies": {
    "@baas/conformance": "workspace:^",
    "@baas/migrate-conformance": "workspace:^",
    "@supabase/supabase-js": "^2",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
