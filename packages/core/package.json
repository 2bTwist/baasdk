{
  "name": "@baas/core",
  "version": "0.1.0",
  "description": "Port layer for the universal Backend-as-a-Service SDK. Interfaces and types only, no implementation.",
  "keywords": [
    "baas",
    "backend-as-a-service",
    "ports-and-adapters",
    "typescript",
    "esm",
    "abstraction",
    "adapter-pattern",
    "capabilities",
    "document-store",
    "contract"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2bTwist/baasdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/2bTwist/baasdk/tree/main/packages/core#readme",
  "bugs": "https://github.com/2bTwist/baasdk/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint:publish": "publint --strict && attw --pack . --profile esm-only"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  }
}
