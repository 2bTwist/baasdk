{
  "name": "@baas/core",
  "version": "0.0.0",
  "description": "Port layer for the universal Backend-as-a-Service SDK. Interfaces and types only, no implementation.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint:publish": "publint --strict && attw --pack . --profile esm-only"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  }
}
