{
  "name": "@baas/adapter-convex",
  "version": "0.0.0",
  "description": "Convex adapter for @baas/core: reactive document store, JWT-verify auth, file storage, and deployable schemaless CRUD helpers (the ./convex entry), behind the ports.",
  "keywords": [
    "baas",
    "backend-as-a-service",
    "ports-and-adapters",
    "typescript",
    "esm",
    "convex",
    "reactive",
    "realtime",
    "auth",
    "file-storage"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2bTwist/baasdk.git",
    "directory": "packages/adapter-convex"
  },
  "homepage": "https://github.com/2bTwist/baasdk/tree/main/packages/adapter-convex#readme",
  "bugs": "https://github.com/2bTwist/baasdk/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./convex": {
      "types": "./dist/convex.d.ts",
      "import": "./dist/convex.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.convex.json",
    "convex:codegen": "convex codegen",
    "lint:publish": "publint --strict && attw --pack . --profile esm-only"
  },
  "peerDependencies": {
    "convex": "^1"
  },
  "dependencies": {
    "@baas/core": "workspace:^"
  },
  "devDependencies": {
    "@baas/conformance": "workspace:^",
    "@baas/migrate-conformance": "workspace:^",
    "@edge-runtime/vm": "^5",
    "convex": "^1",
    "convex-test": "^0.0.53",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
