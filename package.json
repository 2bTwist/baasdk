{
  "name": "baasdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:boundaries": "depcruise packages --config .dependency-cruiser.cjs",
    "lint:types": "eslint packages --max-warnings=0",
    "metrics": "depcruise packages --config .dependency-cruiser.cjs --output-type metrics",
    "format": "biome format --write .",
    "verify": "biome ci --error-on-warnings . && pnpm lint:boundaries && pnpm lint:types && turbo run typecheck build && vitest run",
    "release": "changeset publish",
    "lint:publish": "pnpm -r run lint:publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "^2",
    "@changesets/cli": "^2",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@types/node": "^25.9.3",
    "@typescript-eslint/utils": "^8.61.1",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.39.4",
    "eslint-plugin-functional": "^10.0.0",
    "lefthook": "^2.1.9",
    "publint": "^0.3.21",
    "tsup": "^8",
    "turbo": "^2",
    "typescript": "^5.7",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3"
  }
}
