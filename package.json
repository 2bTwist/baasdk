{
  "name": "baasdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Thin, honest TypeScript ports-and-adapters SDK over backend-as-a-service providers (Supabase, Convex, in-memory): portable document CRUD, auth, and file storage with declared capabilities, one shared conformance suite, and a typed native() escape hatch.",
  "keywords": [
    "baas",
    "backend-as-a-service",
    "supabase",
    "convex",
    "ports-and-adapters",
    "adapter-pattern",
    "typescript",
    "abstraction-layer",
    "conformance-testing"
  ],
  "homepage": "https://github.com/2bTwist/baasdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2bTwist/baasdk.git"
  },
  "bugs": "https://github.com/2bTwist/baasdk/issues",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "typecheck:examples": "tsc -p examples/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "node scripts/demo.mjs",
    "lint": "biome check .",
    "lint:boundaries": "depcruise packages --config .dependency-cruiser.cjs",
    "lint:types": "eslint packages examples --max-warnings=0",
    "metrics": "depcruise packages --config .dependency-cruiser.cjs --output-type metrics",
    "format": "biome format --write .",
    "knip": "knip",
    "size": "size-limit",
    "docs:capabilities": "node scripts/capability-matrix.mjs",
    "docs:quickstart": "node scripts/quickstart-snippet.mjs",
    "docs:api": "typedoc",
    "docs:api:check": "typedoc --emit none",
    "verify": "biome ci --error-on-warnings . && pnpm lint:boundaries && pnpm lint:types && turbo run typecheck build && pnpm typecheck:examples && node scripts/capability-matrix.mjs --check && node scripts/quickstart-snippet.mjs --check && pnpm docs:api:check && vitest run",
    "release": "changeset publish",
    "lint:publish": "pnpm -r run lint:publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "^2",
    "@changesets/cli": "^2",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/node": "^25.9.3",
    "@typescript-eslint/utils": "^8.61.1",
    "dependency-cruiser": "^17.4.3",
    "esbuild": "0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-functional": "^10.0.0",
    "knip": "^6.17.1",
    "lefthook": "^2.1.9",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "turbo": "^2",
    "typedoc": "^0.28.19",
    "typescript": "^5.7",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3"
  }
}
