# Marquee live backends (Phase 1). Copy to .env.local and fill in.
# .env.local is gitignored; the Convex CLI also writes VITE_CONVEX_URL there.

# Which backend to start on: memory | supabase | convex
VITE_BAAS_BACKEND=memory

# Live Supabase (from `supabase status --workdir apps/marquee -o env`).
# Marquee's local instance runs on the +1000 port offset (55321).
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_ANON_KEY=

# Live Convex (written automatically by `npx convex dev` in apps/marquee).
VITE_CONVEX_URL=http://127.0.0.1:3210
